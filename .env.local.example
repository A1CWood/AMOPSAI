# Copy to .env.local and fill in from your Supabase project settings.
# .env.local is gitignored by default (see .gitignore) - never commit real values.

# Public - safe to expose to the browser, also set in Vercel Project Settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret - local-only, used solely by scripts/migrate-contacts.ts.
# Do NOT add this to Vercel; no runtime feature needs it.
SUPABASE_SERVICE_ROLE_KEY=
